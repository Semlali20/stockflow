# Copy this file to `.env` (same folder) and fill in the values:
#   cp .env.example .env
# docker-compose automatically reads `.env` from this directory.

# ---------------------------------------------------------------------------
# SERVER_IP — the address users type in their browser to reach this machine.
# Leave as "localhost" for local use, or set it to the host's LAN/public IP
# (e.g. 192.168.1.50) so emailed links/notifications point back to the server.
#
# NOTE: you do NOT need to rebuild the frontend when this changes. The web UI
# calls /api on its own origin and nginx proxies it to the gateway, so opening
# http://<SERVER_IP>:3000 from any machine just works.
# ---------------------------------------------------------------------------
SERVER_IP=localhost

# ---------------------------------------------------------------------------
# Secrets
# ---------------------------------------------------------------------------
# Strong random string used to sign/verify JWTs (shared by gateway + services).
JWT_SECRET=change-me-to-a-long-random-string

# SMTP credentials for verification + alert emails (Gmail app password, etc.).
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Address that receives low-stock / system alert emails.
ADMIN_EMAIL=admin@example.com
